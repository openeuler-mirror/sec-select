#!/bin/bash

# Determine the path to secafs
if [ -n "$SECAFS_BIN" ]; then
    SECAFS_PATH="$SECAFS_BIN"
else
    SECAFS_PATH="$(which secafs 2>/dev/null)"
    if [ -z "$SECAFS_PATH" ]; then
        echo "Error: secafs binary not found. Please install secafs or set SECAFS_BIN." >&2
        exit 1
    fi
fi

"$SECAFS_PATH" mount "$1" "$2"
