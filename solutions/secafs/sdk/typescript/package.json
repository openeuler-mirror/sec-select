{
  "name": "secafs-sdk",
  "version": "0.7.0",
  "description": "SecAFS SDK - Secure Agent Filesystem (PostgreSQL)",
  "main": "dist/index_node.js",
  "types": "dist/index_node.d.ts",
  "packageManager": "npm@10.9.0",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "exports": {
    ".": {
      "node": "./dist/index_node.js",
      "browser": "./dist/index_browser.js",
      "default": "./dist/index_node.js"
    },
    "./just-bash": {
      "import": "./dist/integrations/just-bash/index.js",
      "types": "./dist/integrations/just-bash/index.d.ts"
    },
    "./cloudflare": {
      "import": "./dist/integrations/cloudflare/index.js",
      "types": "./dist/integrations/cloudflare/index.d.ts"
    }
  },
  "keywords": [
    "ai",
    "agent",
    "postgres",
    "key-value",
    "filesystem",
    "secafs"
  ],
  "author": "",
  "license": "MulanPSL-2.0",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/pg": "^8.11.0",
    "@vitest/ui": "^4.0.1",
    "just-bash": "^2.0.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.1"
  },
  "peerDependencies": {
    "just-bash": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "just-bash": {
      "optional": true
    }
  },
  "dependencies": {
    "buffer": "^6.0.3",
    "pg": "^8.11.5"
  },
  "files": [
    "dist"
  ]
}
